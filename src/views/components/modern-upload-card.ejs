<!-- Modern Media Upload Card -->
<div class="admin-surface-card overflow-hidden">
    <div class="admin-surface-header">
        <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center">
                <i class="fas fa-upload text-white"></i>
            </div>
            <div>
                <h3 class="text-xl font-semibold tracking-tight text-slate-900" id="upload-title">Upload Video</h3>
                <p class="text-sm text-slate-600" id="upload-subtitle">Supported formats: MP4, AVI, MOV (Max: 800MB)</p>
            </div>
        </div>
    </div>
    
    <div class="px-5 py-4">
        <!-- Hidden File Input -->
        <input type="file" id="file-input" accept="video/*,audio/*,image/*" style="display: none;">
        
        <!-- Modern Drag & Drop Zone -->
        <div class="relative group">
            <div class="border-2 border-dashed border-slate-300 rounded-2xl p-6 md:p-7 text-center transition-all duration-300 hover:border-indigo-400 hover:bg-indigo-50/50 cursor-pointer min-h-[250px] flex items-center justify-center bg-gradient-to-b from-white to-slate-50/40" id="drop-zone">
                <div class="space-y-3 w-full">
                    <!-- Upload Icon with Animation -->
                    <div class="mx-auto w-14 h-14 bg-gradient-to-br from-indigo-100 to-purple-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                        <i class="fas fa-cloud-upload-alt text-xl text-blue-600" id="upload-icon"></i>
                    </div>
                    
                    <!-- Upload Text -->
                    <div class="space-y-2">
                        <h4 class="text-xl font-semibold tracking-tight text-slate-900" id="upload-text">Upload Video</h4>
                        <p class="text-sm text-slate-600">Drag and drop your video files here, or click to browse</p>
                        <div class="flex items-center justify-center space-x-4 text-xs text-slate-500">
                            <span class="flex items-center">
                                <i class="fas fa-check-circle text-green-500 mr-1"></i>
                                Max 800MB
                            </span>
                            <span class="flex items-center">
                                <i class="fas fa-shield-alt text-blue-500 mr-1"></i>
                                Secure upload
                            </span>
                        </div>
                    </div>
                    
                    <!-- Upload Button -->
                    <button type="button" class="inline-flex items-center px-5 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold rounded-xl hover:from-indigo-700 hover:to-purple-700 transition-all duration-300 shadow-md hover:shadow-xl hover:-translate-y-0.5" id="choose-files-btn">
                        <i class="fas fa-folder-open mr-2"></i>
                        Choose Files
                    </button>
                </div>
            </div>
            
            <!-- Upload Progress (Hidden by default) -->
            <div id="upload-progress" class="hidden mt-4">
                <div class="bg-gray-200 rounded-full h-2 overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-500 to-indigo-600 h-full transition-all duration-300" style="width: 0%"></div>
                </div>
                <p class="text-sm text-gray-600 mt-2 text-center">Uploading...</p>
            </div>
        </div>

        <!-- File Preview -->
        <div id="file-preview" class="mt-4 hidden">
            <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-4 border border-green-200">
                <div class="flex items-center space-x-4">
                    <div class="flex-shrink-0">
                        <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl flex items-center justify-center">
                            <i class="fas fa-check text-white" id="file-icon"></i>
                        </div>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-gray-900 truncate" id="file-name"></p>
                        <p class="text-sm text-gray-600" id="file-size"></p>
                    </div>
                    <button type="button" class="text-red-500 hover:text-red-700 p-2 rounded-lg hover:bg-red-50 transition-colors" id="remove-file">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
