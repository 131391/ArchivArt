<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        headline: ['Space Grotesk', 'sans-serif'],
                        body: ['Manrope', 'sans-serif'],
                        label: ['Inter', 'sans-serif']
                    }
                }
            }
        };
    </script>
    <style>
        .landing-shell {
            background: #0d0d1c !important;
            color: #e9e6fc !important;
            min-height: 100vh;
        }
        .glass-panel {
            background: rgba(36, 36, 58, 0.6);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }
        .soft-card {
            background: #1e1e32;
            box-shadow: inset 1px 1px 0 rgba(233, 230, 252, 0.05);
            border-radius: 0.85rem;
            border: 1px solid rgba(117, 115, 135, 0.18);
        }
        .text-glow-primary {
            text-shadow: 0 0 15px rgba(197, 154, 255, 0.4);
        }
        .section-edge {
            background: #121222;
        }
        .section-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(117, 115, 135, 0.45), transparent);
        }
    </style>
</head>
<body class="landing-shell font-body selection:bg-purple-400 selection:text-black" style="background:#0d0d1c !important; color:#e9e6fc !important;">
    <nav class="fixed top-0 w-full z-50 bg-[#0d0d1c]/60 backdrop-blur-xl shadow-2xl shadow-black/40" style="background:rgba(13,13,28,.72) !important;">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <% if (settings && settings.logo_path) { %>
                    <img src="<%= settings.logo_path %>" alt="<%= settings.site_name || 'ArchivArt' %>" class="h-9 sm:h-10 w-auto object-contain">
                <% } else { %>
                    <span class="text-2xl font-bold tracking-tighter text-white font-headline">ArchivArt</span>
                <% } %>
            </div>
            <div class="hidden md:flex gap-7 items-center">
                <a class="font-headline tracking-tight text-xs font-semibold text-[#c59aff] border-b-2 border-[#c59aff] pb-1" href="#features">Features</a>
                <a class="font-headline tracking-tight text-xs font-semibold text-slate-400 hover:text-white transition-colors" href="#how-it-works">How It Works</a>
                <a class="font-headline tracking-tight text-xs font-semibold text-slate-400 hover:text-white transition-colors" href="/builds/ArchivART-V2.apk" download="ArchivART-V2.apk" onclick="trackDownload()">Download</a>
            </div>
            <div class="flex items-center gap-3">
                <a href="/admin/login" class="hidden sm:inline-flex bg-gradient-to-br from-[#c59aff] to-[#9547f7] text-[#1b0b33] font-headline text-xs font-bold px-4 py-2 rounded-xl transition-all duration-300 active:scale-95">Admin Portal</a>
                <label for="mobile-nav-toggle" class="md:hidden text-slate-300 hover:text-white cursor-pointer">
                    <i class="fas fa-bars text-lg"></i>
                </label>
            </div>
        </div>
        <input id="mobile-nav-toggle" type="checkbox" class="peer sr-only md:hidden">
        <div id="mobile-menu" class="hidden peer-checked:block md:hidden px-4 pb-4 absolute top-full left-0 right-0 z-50">
            <div class="glass-panel rounded-xl p-3 flex flex-col gap-2 border border-white/10 bg-[#131429]/95">
                <a href="#features" onclick="document.getElementById('mobile-nav-toggle').checked=false" class="text-sm text-slate-100 hover:text-white px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">Features</a>
                <a href="#how-it-works" onclick="document.getElementById('mobile-nav-toggle').checked=false" class="text-sm text-slate-100 hover:text-white px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">How It Works</a>
                <a href="/builds/ArchivART-V2.apk" download="ArchivART-V2.apk" onclick="trackDownload();document.getElementById('mobile-nav-toggle').checked=false" class="text-sm text-slate-100 hover:text-white px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">Download</a>
                <a href="/admin/login" onclick="document.getElementById('mobile-nav-toggle').checked=false" class="text-sm text-slate-100 hover:text-white px-3 py-2 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">Admin Portal</a>
            </div>
        </div>
    </nav>

    <section class="relative min-h-screen flex items-center pt-16 overflow-hidden" style="background:linear-gradient(130deg,#0d0d1c 0%,#14162e 50%,#201a3f 100%) !important;">
        <div class="absolute top-[-10%] right-[-10%] w-[600px] h-[600px] bg-purple-400/20 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-[10%] left-[-5%] w-[420px] h-[420px] bg-cyan-400/10 blur-[100px] rounded-full"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center relative z-10">
            <div class="lg:pr-4">
                <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.03] tracking-tight text-white mb-5" style="color:#ffffff !important;">
                    Bring Images <br><span class="text-[#c59aff] text-glow-primary">To Life</span>
                </h1>
                <p class="text-[#aba9be] text-sm sm:text-base md:text-lg max-w-xl mb-8 leading-relaxed" style="color:#b9b6cd !important;">
                    <%= message %> ArchivArt unifies AR experiences and OCR intelligence into one premium platform for immersive digital storytelling.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="/builds/ArchivART-V2.apk" download="ArchivART-V2.apk" onclick="trackDownload()" class="px-6 py-3.5 bg-gradient-to-br from-[#c59aff] to-[#9547f7] text-white font-bold rounded-xl text-sm sm:text-base hover:shadow-lg hover:shadow-purple-500/25 transition-all active:scale-95">
                        Download Mobile App
                    </a>
                    <a href="#how-it-works" class="px-6 py-3.5 glass-panel text-[#00f4fe] font-bold rounded-xl text-sm sm:text-base hover:bg-cyan-400/10 transition-all active:scale-95">
                        See How It Works
                    </a>
                </div>
            </div>
            <div class="relative lg:pl-4">
                <div class="relative z-20 transform lg:translate-x-10 hover:scale-[1.02] transition-transform duration-500">
                    <img class="rounded-[2rem] shadow-2xl shadow-black/60 object-cover w-full aspect-[4/5] lg:aspect-[4/4.8]" src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?auto=format&fit=crop&w=900&q=80" alt="AR preview">
                    <div class="absolute -top-6 -left-6 glass-panel p-4 rounded-2xl shadow-xl">
                        <p class="text-[10px] font-label text-[#00f4fe] tracking-widest uppercase">Target Found</p>
                    </div>
                    <div class="absolute -bottom-8 -right-6 glass-panel p-5 rounded-2xl shadow-xl">
                        <div class="flex items-center gap-2 mb-2">
                            <i class="fas fa-layer-group text-[#c59aff]"></i>
                            <span class="font-headline text-white font-bold text-sm">AR + OCR</span>
                        </div>
                        <div class="h-1.5 w-28 bg-slate-900 rounded-full overflow-hidden">
                            <div class="h-full bg-gradient-to-r from-[#c59aff] to-[#00f4fe] w-2/3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <div class="section-divider"></div>

    <section id="features" class="py-20 section-edge" style="background:#121222 !important;">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="mb-14">
                <h2 class="font-headline text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">AR + OCR Intelligence</h2>
                <div class="h-1 w-24 bg-gradient-to-r from-[#c59aff] to-[#00f4fe]"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="soft-card p-7 hover:bg-[#24243a] transition-all duration-300">
                    <div class="w-12 h-12 rounded-lg bg-purple-400/10 flex items-center justify-center mb-5 text-xl text-[#c59aff]"><i class="fas fa-vr-cardboard"></i></div>
                    <h3 class="font-headline text-lg sm:text-xl font-bold text-white mb-3">Interactive AR Media</h3>
                    <p class="text-[#aba9be] text-sm leading-relaxed">Embed videos, 3D moments, and contextual audio into physical markers for premium user engagement.</p>
                </div>
                <div class="soft-card p-7 hover:bg-[#24243a] transition-all duration-300">
                    <div class="w-12 h-12 rounded-lg bg-cyan-400/10 flex items-center justify-center mb-5 text-xl text-[#00f4fe]"><i class="fas fa-camera"></i></div>
                    <h3 class="font-headline text-lg sm:text-xl font-bold text-white mb-3">Fast AR Scan</h3>
                    <p class="text-[#aba9be] text-sm leading-relaxed">Low-latency recognition and instant trigger playback make real-world interactions feel seamless.</p>
                </div>
                <div class="soft-card p-7 hover:bg-[#24243a] transition-all duration-300">
                    <div class="w-12 h-12 rounded-lg bg-pink-400/10 flex items-center justify-center mb-5 text-xl text-[#ff5ed6]"><i class="fas fa-file-lines"></i></div>
                    <h3 class="font-headline text-lg sm:text-xl font-bold text-white mb-3">OCR Read</h3>
                    <p class="text-[#aba9be] text-sm leading-relaxed">Extract text from labels and documents using provider-switching OCR pipelines with structured outputs.</p>
                </div>
            </div>
        </div>
    </section>
    <div class="section-divider"></div>

    <section id="how-it-works" class="py-20" style="background:#0d0d1c !important;">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="font-headline text-4xl md:text-6xl font-bold text-white mb-3">Experience Synthesis</h2>
                <p class="text-[#aba9be] max-w-2xl mx-auto">Three steps to bridge physical archives and digital intelligence with ArchivArt.</p>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 relative">
                <div class="hidden lg:block absolute left-0 right-0 top-10 h-px bg-gradient-to-r from-transparent via-[#474658] to-transparent"></div>
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[#1e1e32] border-2 border-[#c59aff] text-[#c59aff] text-3xl font-headline font-bold mb-7 shadow-lg shadow-purple-500/20">1</div>
                    <h4 class="font-headline text-xl md:text-2xl font-bold text-white mb-3">Upload</h4>
                    <p class="text-[#aba9be]">Upload your visual markers and media from the admin portal.</p>
                </div>
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[#1e1e32] border-2 border-[#00f4fe] text-[#00f4fe] text-3xl font-headline font-bold mb-7 shadow-lg shadow-cyan-500/20">2</div>
                    <h4 class="font-headline text-xl md:text-2xl font-bold text-white mb-3">Add Rules</h4>
                    <p class="text-[#aba9be]">Configure AR behavior and OCR extraction settings in one workflow.</p>
                </div>
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-[#1e1e32] border-2 border-[#ff5ed6] text-[#ff5ed6] text-3xl font-headline font-bold mb-7 shadow-lg shadow-pink-500/20">3</div>
                    <h4 class="font-headline text-xl md:text-2xl font-bold text-white mb-3">Scan & Experience</h4>
                    <p class="text-[#aba9be]">Users scan and instantly unlock AR content while OCR reads contextual text.</p>
                </div>
            </div>
        </div>
    </section>
    <div class="section-divider"></div>

    <section id="download" class="py-20 section-edge" style="background:#121222 !important;">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="glass-panel rounded-[2rem] overflow-hidden flex flex-col lg:flex-row items-center">
                <div class="p-8 sm:p-10 lg:p-14 flex-1">
                    <div class="inline-block px-4 py-1 rounded-full bg-cyan-400/10 text-[#00f4fe] font-label text-xs font-bold tracking-widest uppercase mb-5">Platform Specs</div>
                    <h2 class="font-headline text-3xl sm:text-4xl font-bold text-white mb-7">The Mobile Powerhouse</h2>
                    <ul class="space-y-5 mb-8">
                        <li class="flex items-start gap-3"><i class="fas fa-check-circle text-[#c59aff] mt-1"></i><div><div class="text-white font-bold">Android 7.0+ Optimized</div><div class="text-[#aba9be] text-sm">AR-ready mobile experience with smooth scanning.</div></div></li>
                        <li class="flex items-start gap-3"><i class="fas fa-check-circle text-[#c59aff] mt-1"></i><div><div class="text-white font-bold">Lightweight Build</div><div class="text-[#aba9be] text-sm">Fast install and efficient runtime footprint.</div></div></li>
                        <li class="flex items-start gap-3"><i class="fas fa-check-circle text-[#c59aff] mt-1"></i><div><div class="text-white font-bold">Real-time OCR Engine</div><div class="text-[#aba9be] text-sm">Hybrid provider support for accurate extraction.</div></div></li>
                    </ul>
                    <a href="/builds/ArchivART-V2.apk" download="ArchivART-V2.apk" onclick="trackDownload()" class="inline-flex items-center gap-3 bg-black px-6 py-3 rounded-xl border border-white/10 hover:bg-white/5 transition-colors">
                        <i class="fab fa-google-play text-white"></i>
                        <div>
                            <div class="text-[10px] uppercase text-slate-400">Get it on</div>
                            <div class="text-sm font-bold text-white">Google Play (APK)</div>
                        </div>
                    </a>
                </div>
                <div class="lg:w-1/2 w-full min-h-[320px] relative">
                    <img class="absolute inset-0 w-full h-full object-cover" src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1000&q=80" alt="Mobile app preview">
                    <div class="absolute inset-0 bg-gradient-to-t from-[#18182a] via-transparent lg:bg-gradient-to-l"></div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-[#0d0d1c] w-full py-12 px-4 sm:px-6 lg:px-8" style="background:#0d0d1c !important;">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="text-center md:text-left">
                <% if (settings && settings.logo_path) { %>
                    <img src="<%= settings.logo_path %>" alt="<%= settings.site_name || 'ArchivArt' %>" class="h-10 w-auto object-contain mb-3 mx-auto md:mx-0">
                <% } else { %>
                    <div class="text-lg font-bold text-white mb-2 font-headline">ArchivArt</div>
                <% } %>
                <p class="text-xs text-slate-500">© 2026 ArchivArt. Immersive Synthesis Design.</p>
            </div>
            <div class="flex flex-wrap justify-center gap-8">
                <a class="text-xs text-slate-500 hover:text-[#00f4fe] transition-colors" href="#features">Features</a>
                <a class="text-xs text-slate-500 hover:text-[#00f4fe] transition-colors" href="#how-it-works">How It Works</a>
                <a class="text-xs text-slate-500 hover:text-[#00f4fe] transition-colors" href="/builds/ArchivART-V2.apk" download="ArchivART-V2.apk" onclick="trackDownload()">Download</a>
                <a class="text-xs text-slate-500 hover:text-[#00f4fe] transition-colors" href="/admin/login">Admin Portal</a>
            </div>
        </div>
    </footer>

    <script>
        function trackDownload() {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'download', {
                    event_category: 'APK',
                    event_label: 'ArchivART-V2.apk',
                    value: 1
                });
            }
        }

        // Menu uses CSS peer-checked toggle for reliability on mobile.
    </script>
</body>
</html>
