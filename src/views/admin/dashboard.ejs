<!-- Dashboard Content -->
<div class="space-y-6">
    <!-- Welcome Section -->
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-indigo-600 via-purple-600 to-fuchsia-600 px-5 py-6 text-white shadow-sm sm:px-6 lg:px-8">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,.25),transparent_45%)]"></div>
        <div class="relative z-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-2xl font-bold sm:text-3xl">Welcome back, Admin</h1>
                <p class="mt-1.5 text-sm text-indigo-100 sm:text-base">Here is a quick overview of your ArchivArt platform today.</p>
            </div>
            <div class="hidden sm:flex h-14 w-14 items-center justify-center rounded-xl bg-white/15 backdrop-blur-sm">
                <i class="fas fa-chart-line text-xl text-white"></i>
            </div>
        </div>
    </section>

    <!-- Stats Cards -->
    <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <!-- Total Users -->
        <div class="admin-surface-card admin-surface-card-hover p-5">
            <div class="mb-4 flex items-start justify-between">
                <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-blue-100 text-blue-600">
                    <i class="fas fa-users text-lg"></i>
                </div>
                <div class="text-right">
                    <p class="text-2xl font-bold text-slate-900"><%= stats.totalUsers || 0 %></p>
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Total Users</p>
                </div>
            </div>
            <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name && p.name.startsWith('users.'))) { %>
            <a href="/admin/users" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-700">
                View all users
                <i class="fas fa-arrow-right ml-2 text-xs"></i>
            </a>
            <% } else { %>
            <span class="inline-flex items-center text-sm font-medium text-slate-400">
                <i class="fas fa-lock mr-2 text-xs"></i>
                View all users
            </span>
            <% } %>
        </div>

        <!-- Total Media -->
        <div class="admin-surface-card admin-surface-card-hover p-5">
            <div class="mb-4 flex items-start justify-between">
                <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-100 text-emerald-600">
                    <i class="fas fa-images text-lg"></i>
                </div>
                <div class="text-right">
                    <p class="text-2xl font-bold text-slate-900"><%= stats.totalMedia || 0 %></p>
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Total Media</p>
                </div>
            </div>
            <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name && p.name.startsWith('media.view'))) { %>
            <a href="/admin/media" class="inline-flex items-center text-sm font-medium text-emerald-600 hover:text-emerald-700">
                View all media
                <i class="fas fa-arrow-right ml-2 text-xs"></i>
            </a>
            <% } else { %>
            <span class="inline-flex items-center text-sm font-medium text-slate-400">
                <i class="fas fa-lock mr-2 text-xs"></i>
                View all media
            </span>
            <% } %>
        </div>

        <!-- Videos -->
        <div class="admin-surface-card admin-surface-card-hover p-5">
            <div class="mb-4 flex items-start justify-between">
                <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-violet-100 text-violet-600">
                    <i class="fas fa-video text-lg"></i>
                </div>
                <div class="text-right">
                    <p class="text-2xl font-bold text-slate-900"><%= stats.totalVideos || 0 %></p>
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Videos</p>
                </div>
            </div>
            <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name && p.name.startsWith('media.view'))) { %>
            <a href="/admin/media?type=video" class="inline-flex items-center text-sm font-medium text-violet-600 hover:text-violet-700">
                View videos
                <i class="fas fa-arrow-right ml-2 text-xs"></i>
            </a>
            <% } else { %>
            <span class="inline-flex items-center text-sm font-medium text-slate-400">
                <i class="fas fa-lock mr-2 text-xs"></i>
                View videos
            </span>
            <% } %>
        </div>

        <!-- Audio -->
        <div class="admin-surface-card admin-surface-card-hover p-5">
            <div class="mb-4 flex items-start justify-between">
                <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-amber-100 text-amber-600">
                    <i class="fas fa-music text-lg"></i>
                </div>
                <div class="text-right">
                    <p class="text-2xl font-bold text-slate-900"><%= stats.totalAudio || 0 %></p>
                    <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Audio</p>
                </div>
            </div>
            <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name && p.name.startsWith('media.view'))) { %>
            <a href="/admin/media?type=audio" class="inline-flex items-center text-sm font-medium text-amber-600 hover:text-amber-700">
                View audio
                <i class="fas fa-arrow-right ml-2 text-xs"></i>
            </a>
            <% } else { %>
            <span class="inline-flex items-center text-sm font-medium text-slate-400">
                <i class="fas fa-lock mr-2 text-xs"></i>
                View audio
            </span>
            <% } %>
        </div>
    </section>

    <!-- Recent Activity -->
    <section class="grid grid-cols-1 gap-6 xl:grid-cols-2">
        <!-- Recent Users -->
        <div class="admin-surface-card overflow-hidden">
            <div class="admin-surface-header bg-gradient-to-r from-blue-50 to-indigo-50">
                <div class="flex items-center justify-between">
                    <h3 class="text-lg font-semibold text-slate-900 flex items-center">
                        <span class="mr-3 inline-flex h-8 w-8 items-center justify-center rounded-lg bg-blue-100 text-blue-600">
                            <i class="fas fa-user-plus text-sm"></i>
                        </span>
                        Recent Users
                    </h3>
                </div>
            </div>
            <div class="p-5 sm:p-6">
                <div class="space-y-3">
                    <% if (recentUsers && recentUsers.length > 0) { %>
                    <% recentUsers.forEach((user, index) => { %>
                    <div class="flex items-center gap-3 rounded-xl border border-slate-100 p-3">
                        <div class="relative">
                            <img class="h-11 w-11 rounded-full object-cover" src="https://ui-avatars.com/api/?name=<%= user.name %>&background=random&size=48" alt="<%= user.name %>">
                            <span class="absolute -bottom-1 -right-1 h-3.5 w-3.5 rounded-full border-2 border-white bg-emerald-400"></span>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-semibold text-slate-900"><%= user.name %></p>
                            <p class="truncate text-xs text-slate-500"><%= user.email %></p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-slate-400"><%= new Date(user.created_at).toLocaleDateString() %></p>
                            <p class="text-[11px] font-semibold uppercase tracking-wide text-blue-600">New</p>
                        </div>
                    </div>
                    <% }); %>
                    <% } else { %>
                    <div class="py-8 text-center">
                        <div class="mx-auto mb-3 inline-flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <p class="text-sm text-slate-500">No recent users</p>
                    </div>
                    <% } %>
                </div>
                <div class="mt-5 border-t border-slate-100 pt-4">
                    <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name && p.name.startsWith('users.'))) { %>
                    <a href="/admin/users" class="inline-flex w-full items-center justify-center rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
                        View all users
                    </a>
                    <% } else { %>
                    <div class="inline-flex w-full items-center justify-center rounded-xl bg-slate-200 px-4 py-2.5 text-sm font-semibold text-slate-500">
                        <i class="fas fa-lock mr-2 text-xs"></i>
                        View all users
                    </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Recent Media -->
        <div class="admin-surface-card overflow-hidden">
            <div class="admin-surface-header bg-gradient-to-r from-emerald-50 to-teal-50">
                <h3 class="text-lg font-semibold text-slate-900 flex items-center">
                    <span class="mr-3 inline-flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600">
                        <i class="fas fa-photo-video text-sm"></i>
                    </span>
                    Recent Media
                </h3>
            </div>
            <div class="p-5 sm:p-6">
                <div class="space-y-3">
                    <% if (recentMedia && recentMedia.length > 0) { %>
                    <% recentMedia.forEach((media, index) => { %>
                    <div class="flex items-center gap-3 rounded-xl border border-slate-100 p-3">
                        <div class="relative">
                            <% if (media.scanning_image && media.scanning_image.trim() !== '') { %>
                            <img class="h-11 w-11 rounded-lg object-cover" src="<%= (/^(https?:)?\/\//i.test(media.scanning_image) || media.scanning_image.startsWith('/')) ? media.scanning_image : '/uploads/scanning-images/' + media.scanning_image %>" alt="Media thumbnail" onerror="this.classList.add('hidden'); this.nextElementSibling.classList.remove('hidden'); this.nextElementSibling.classList.add('flex');">
                            <div class="hidden h-11 w-11 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600">
                                <i class="fas fa-<%= media.media_type === 'video' ? 'video' : media.media_type === 'audio' ? 'music' : 'image' %>"></i>
                            </div>
                            <% } else { %>
                            <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600">
                                <i class="fas fa-<%= media.media_type === 'video' ? 'video' : media.media_type === 'audio' ? 'music' : 'image' %>"></i>
                            </div>
                            <% } %>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-semibold text-slate-900"><%= media.title || 'Untitled' %></p>
                            <p class="truncate text-xs text-slate-500"><%= media.media_type %></p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-slate-400"><%= media.created_at ? new Date(media.created_at).toLocaleDateString() : '-' %></p>
                            <p class="text-[11px] font-semibold uppercase tracking-wide text-emerald-600">New</p>
                        </div>
                    </div>
                    <% }); %>
                    <% } else { %>
                    <div class="py-8 text-center">
                        <div class="mx-auto mb-3 inline-flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
                            <i class="fas fa-upload"></i>
                        </div>
                        <p class="text-sm text-slate-500">No recent media</p>
                    </div>
                    <% } %>
                </div>
                <div class="mt-5 border-t border-slate-100 pt-4">
                    <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name && p.name.startsWith('media.view'))) { %>
                    <a href="/admin/media" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-700 transition-colors">
                        View all media
                    </a>
                    <% } else { %>
                    <div class="inline-flex w-full items-center justify-center rounded-xl bg-slate-200 px-4 py-2.5 text-sm font-semibold text-slate-500">
                        <i class="fas fa-lock mr-2 text-xs"></i>
                        View all media
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Actions -->
    <section class="admin-surface-card overflow-hidden">
        <div class="admin-surface-header bg-gradient-to-r from-violet-50 to-fuchsia-50">
            <h3 class="text-lg font-semibold text-slate-900 flex items-center">
                <span class="mr-3 inline-flex h-8 w-8 items-center justify-center rounded-lg bg-violet-100 text-violet-600">
                    <i class="fas fa-bolt text-sm"></i>
                </span>
                Quick Actions
            </h3>
        </div>
        <div class="p-5 sm:p-6">
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name === 'media.upload')) { %>
                <a href="/admin/media/upload" class="admin-surface-card admin-surface-card-hover p-4">
                    <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600">
                        <i class="fas fa-upload"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-slate-900">Upload Media</h4>
                    <p class="mt-1 text-xs text-slate-500">Add new videos, audio, and trigger images.</p>
                </a>
                <% } else { %>
                <div class="admin-surface-card p-4 opacity-60">
                    <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-400">
                        <i class="fas fa-lock"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-slate-700">Upload Media</h4>
                    <p class="mt-1 text-xs text-slate-500">Access denied.</p>
                </div>
                <% } %>

                <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name && p.name.startsWith('users.'))) { %>
                <a href="/admin/users" class="admin-surface-card admin-surface-card-hover p-4">
                    <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600">
                        <i class="fas fa-users"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-slate-900">Manage Users</h4>
                    <p class="mt-1 text-xs text-slate-500">View and manage user accounts.</p>
                </a>
                <% } else { %>
                <div class="admin-surface-card p-4 opacity-60">
                    <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-400">
                        <i class="fas fa-lock"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-slate-700">Manage Users</h4>
                    <p class="mt-1 text-xs text-slate-500">Access denied.</p>
                </div>
                <% } %>

                <% if (typeof userPermissions !== 'undefined' && userPermissions.some(p => p.name === 'rbac.view')) { %>
                <a href="/admin/rbac" class="admin-surface-card admin-surface-card-hover p-4">
                    <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-violet-100 text-violet-600">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-slate-900">RBAC Management</h4>
                    <p class="mt-1 text-xs text-slate-500">Manage roles and permissions.</p>
                </a>
                <% } else { %>
                <div class="admin-surface-card p-4 opacity-60">
                    <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-400">
                        <i class="fas fa-lock"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-slate-700">RBAC Management</h4>
                    <p class="mt-1 text-xs text-slate-500">Access denied.</p>
                </div>
                <% } %>
            </div>
        </div>
    </section>
</div>

<% if (success_msg && success_msg.length > 0) { %>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Show login success toaster
        if (typeof showSuccessToast === 'function') {
            showSuccessToast('<%= success_msg %>');
        } else if (typeof toaster !== 'undefined') {
            toaster.success({
                title: 'Success!',
                description: '<%= success_msg %>'
            });
        }
    });
</script>
<% } %>
