<div class="space-y-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
        <div class="bg-white border border-slate-200 rounded-xl p-4">
            <p class="text-xs text-slate-500">Total Runs</p>
            <p class="text-2xl font-semibold text-slate-900"><%= stats.total || 0 %></p>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-4">
            <p class="text-xs text-slate-500">Success</p>
            <p class="text-2xl font-semibold text-emerald-600"><%= stats.success_count || 0 %></p>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-4">
            <p class="text-xs text-slate-500">Failed</p>
            <p class="text-2xl font-semibold text-rose-600"><%= stats.failed_count || 0 %></p>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-4">
            <p class="text-xs text-slate-500">Google</p>
            <p class="text-2xl font-semibold text-indigo-600"><%= stats.google_count || 0 %></p>
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-4">
            <p class="text-xs text-slate-500">Tesseract</p>
            <p class="text-2xl font-semibold text-amber-600"><%= stats.tesseract_count || 0 %></p>
        </div>
    </div>
</div>

<%
const headerButtons = [
    {
        text: 'Manage in Settings',
        href: '/admin/settings',
        icon: 'fas fa-cog',
        class: 'inline-flex items-center px-6 py-3 border border-transparent text-sm font-semibold rounded-xl text-white bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl'
    }
];

const columns = [
    { key: 'media_title', label: 'Media', sortable: false, type: 'custom', formatter: (item) => `
        <a href="/admin/ocr/${item.id}" class="text-indigo-600 hover:text-indigo-800 font-semibold">
            ${item.media_title || ('Media #' + item.media_id)}
        </a>
        <div class="text-xs text-slate-500 capitalize">${item.media_type || '-'} • OCR #${item.id}</div>
    ` },
    { key: 'provider', label: 'Provider', sortable: false, type: 'custom', formatter: (item) => `
        <span class="capitalize text-sm text-slate-700">${item.provider || '-'}</span>
    ` },
    { key: 'status', label: 'Status', sortable: false, type: 'custom', formatter: (item) => `
        <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-semibold ${item.status === 'success' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700'}">
            ${item.status || '-'}
        </span>
    ` },
    { key: 'language', label: 'Language', sortable: false, type: 'custom', formatter: (item) => `
        <span class="text-sm text-slate-700">${item.language || '-'}</span>
    ` },
    { key: 'confidence', label: 'Confidence', sortable: false, type: 'custom', formatter: (item) => `
        <span class="text-sm text-slate-700">${item.confidence !== null && item.confidence !== undefined ? Number(item.confidence).toFixed(2) + '%' : '-'}</span>
    ` },
    { key: 'processed_at', label: 'Processed', sortable: false, type: 'custom', formatter: (item) => `
        <span class="text-sm text-slate-700">${item.processed_at ? new Date(item.processed_at).toLocaleString() : '-'}</span>
    ` },
    { key: 'extracted_text', label: 'Preview', sortable: false, type: 'custom', formatter: (item) => `
        <span class="text-sm text-slate-600">${item.extracted_text ? `${item.extracted_text.substring(0, 120)}${item.extracted_text.length > 120 ? '...' : ''}` : '-'}</span>
    ` }
];

const actions = [
    {
        icon: () => 'fas fa-eye',
        title: () => 'View OCR',
        class: 'text-indigo-600 hover:text-indigo-900',
        onclick: (item) => `window.location.href='/admin/ocr/${item.id}'`
    }
];

const tableFilters = [];
%>

<%- include('../components/table', {
    title: title,
    data: data,
    headerButtons: headerButtons,
    columns: columns,
    actions: actions,
    pagination: pagination,
    search: filters.search || '',
    filters: tableFilters,
    showSearch: true,
    searchPlaceholder: 'Search media title or OCR text...',
    emptyIcon: 'fas fa-file-signature',
    emptyTitle: 'No OCR Records Found',
    emptyMessage: 'No OCR records are available yet.',
    emptySearchMessage: 'No OCR records match your search criteria.'
}) %>

<script>
    (function () {
        const params = new URLSearchParams(window.location.search);
        const toolbar = document.querySelector('.bg-gradient-to-r.from-slate-50.to-gray-50');
        if (!toolbar) return;

        const controlsWrap = toolbar.querySelector('.flex.flex-col.sm\\:flex-row.space-y-3');
        if (!controlsWrap) return;

        const providerSelectWrap = document.createElement('div');
        providerSelectWrap.className = 'relative';
        providerSelectWrap.innerHTML = `
            <select id="ocrProviderFilter" class="appearance-none px-4 py-3 pr-10 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 bg-white shadow-sm hover:shadow-md cursor-pointer">
                <option value="">All Providers</option>
                <option value="google">Google</option>
                <option value="tesseract">Tesseract</option>
            </select>
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                <i class="fas fa-chevron-down text-gray-400"></i>
            </div>
        `;

        const statusSelectWrap = document.createElement('div');
        statusSelectWrap.className = 'relative';
        statusSelectWrap.innerHTML = `
            <select id="ocrStatusFilter" class="appearance-none px-4 py-3 pr-10 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 bg-white shadow-sm hover:shadow-md cursor-pointer">
                <option value="">All Status</option>
                <option value="success">Success</option>
                <option value="failed">Failed</option>
            </select>
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                <i class="fas fa-chevron-down text-gray-400"></i>
            </div>
        `;

        controlsWrap.appendChild(providerSelectWrap);
        controlsWrap.appendChild(statusSelectWrap);

        const providerEl = document.getElementById('ocrProviderFilter');
        const statusEl = document.getElementById('ocrStatusFilter');
        const searchEl = document.getElementById('searchInput');

        providerEl.value = params.get('provider') || '';
        statusEl.value = params.get('status') || '';

        function applyFilters() {
            const q = new URLSearchParams();
            const searchVal = (searchEl && searchEl.value || '').trim();
            const providerVal = providerEl.value;
            const statusVal = statusEl.value;
            if (searchVal) q.set('search', searchVal);
            if (providerVal) q.set('provider', providerVal);
            if (statusVal) q.set('status', statusVal);
            window.location.href = `/admin/ocr?${q.toString()}`;
        }

        providerEl.addEventListener('change', applyFilters);
        statusEl.addEventListener('change', applyFilters);
    })();
</script>
