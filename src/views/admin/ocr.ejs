<div class="min-h-screen bg-slate-50">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-4 space-y-4">
        <div class="bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-600 rounded-2xl p-5 shadow-lg text-white">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                <div>
                    <h1 class="text-2xl font-semibold">OCR Management</h1>
                    <p class="text-indigo-100 text-sm mt-1">Monitor OCR results separately from AR media management.</p>
                </div>
                <a href="/admin/settings" class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-white/35 bg-white/10 text-sm font-semibold text-white hover:bg-white/20 transition-colors">
                    <i class="fas fa-cog mr-2"></i>
                    Manage in Settings
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
            <div class="bg-white border border-slate-200 rounded-xl p-4">
                <p class="text-xs text-slate-500">Total Runs</p>
                <p class="text-2xl font-semibold text-slate-900"><%= stats.total || 0 %></p>
            </div>
            <div class="bg-white border border-slate-200 rounded-xl p-4">
                <p class="text-xs text-slate-500">Success</p>
                <p class="text-2xl font-semibold text-emerald-600"><%= stats.success_count || 0 %></p>
            </div>
            <div class="bg-white border border-slate-200 rounded-xl p-4">
                <p class="text-xs text-slate-500">Failed</p>
                <p class="text-2xl font-semibold text-rose-600"><%= stats.failed_count || 0 %></p>
            </div>
            <div class="bg-white border border-slate-200 rounded-xl p-4">
                <p class="text-xs text-slate-500">Google</p>
                <p class="text-2xl font-semibold text-indigo-600"><%= stats.google_count || 0 %></p>
            </div>
            <div class="bg-white border border-slate-200 rounded-xl p-4">
                <p class="text-xs text-slate-500">Tesseract</p>
                <p class="text-2xl font-semibold text-amber-600"><%= stats.tesseract_count || 0 %></p>
            </div>
        </div>

        <form method="GET" action="/admin/ocr" class="bg-white border border-slate-200 rounded-xl p-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
                <input
                    type="text"
                    name="search"
                    value="<%= filters.search || '' %>"
                    placeholder="Search media title or OCR text"
                    class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
                >
                <select name="provider" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="">All providers</option>
                    <option value="google" <%= filters.provider === 'google' ? 'selected' : '' %>>Google</option>
                    <option value="tesseract" <%= filters.provider === 'tesseract' ? 'selected' : '' %>>Tesseract</option>
                </select>
                <select name="status" class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="">All status</option>
                    <option value="success" <%= filters.status === 'success' ? 'selected' : '' %>>Success</option>
                    <option value="failed" <%= filters.status === 'failed' ? 'selected' : '' %>>Failed</option>
                </select>
                <button type="submit" class="bg-indigo-600 text-white rounded-lg px-4 py-2 text-sm font-semibold hover:bg-indigo-700 transition-colors sm:col-span-2 lg:col-span-1">
                    Apply Filters
                </button>
            </div>
        </form>

        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Media</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Provider</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Language</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Confidence</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Processed</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase">Preview</th>
                            <th class="px-4 py-3 text-right text-xs font-semibold text-slate-600 uppercase">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% if (!data || !data.length) { %>
                            <tr>
                                <td colspan="8" class="px-4 py-8 text-center text-sm text-slate-500">No OCR records found.</td>
                            </tr>
                        <% } %>
                        <% (data || []).forEach(function(row) { %>
                            <tr class="hover:bg-indigo-50/40 transition-colors">
                                <td class="px-4 py-3 text-sm">
                                    <a href="/admin/ocr/<%= row.id %>" class="text-indigo-600 hover:text-indigo-800 font-semibold">
                                        <%= row.media_title || ('Media #' + row.media_id) %>
                                    </a>
                                    <div class="text-xs text-slate-500 capitalize">
                                        <%= row.media_type || '-' %> • OCR #<%= row.id %>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-sm capitalize text-slate-700"><%= row.provider || '-' %></td>
                                <td class="px-4 py-3 text-sm">
                                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-semibold <%= row.status === 'success' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                                        <%= row.status || '-' %>
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-sm text-slate-700"><%= row.language || '-' %></td>
                                <td class="px-4 py-3 text-sm text-slate-700">
                                    <%= row.confidence !== null && row.confidence !== undefined ? Number(row.confidence).toFixed(2) + '%' : '-' %>
                                </td>
                                <td class="px-4 py-3 text-sm text-slate-700">
                                    <%= row.processed_at ? new Date(row.processed_at).toLocaleString() : '-' %>
                                </td>
                                <td class="px-4 py-3 text-sm text-slate-600 max-w-xs">
                                    <% if (row.extracted_text) { %>
                                        <span class="line-clamp-2"><%= row.extracted_text.substring(0, 120) %><%= row.extracted_text.length > 120 ? '...' : '' %></span>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td class="px-4 py-3 text-sm text-right">
                                    <a href="/admin/ocr/<%= row.id %>" class="inline-flex items-center justify-center rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-1.5 text-xs font-semibold text-indigo-700 hover:bg-indigo-100 transition-colors">
                                        <i class="fas fa-arrow-up-right-from-square mr-1.5"></i>
                                        View OCR
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <% if (pagination && pagination.totalPages > 1) { %>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                <p class="text-sm text-slate-600">
                    Page <%= pagination.currentPage %> of <%= pagination.totalPages %>
                </p>
                <div class="flex items-center gap-2">
                    <% if (pagination.hasPrev) { %>
                        <a
                            href="/admin/ocr?page=<%= pagination.currentPage - 1 %>&search=<%= encodeURIComponent(filters.search || '') %>&provider=<%= encodeURIComponent(filters.provider || '') %>&status=<%= encodeURIComponent(filters.status || '') %>"
                            class="px-3 py-1.5 rounded-lg border border-slate-300 bg-white text-sm text-slate-700 hover:bg-slate-50"
                        >Previous</a>
                    <% } %>
                    <% if (pagination.hasNext) { %>
                        <a
                            href="/admin/ocr?page=<%= pagination.currentPage + 1 %>&search=<%= encodeURIComponent(filters.search || '') %>&provider=<%= encodeURIComponent(filters.provider || '') %>&status=<%= encodeURIComponent(filters.status || '') %>"
                            class="px-3 py-1.5 rounded-lg border border-slate-300 bg-white text-sm text-slate-700 hover:bg-slate-50"
                        >Next</a>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>
