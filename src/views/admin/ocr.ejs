<style>
    .ocr-modern-page .ocr-table-shell {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 0.65rem;
    }
    .ocr-modern-page .ocr-manager-head {
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.13), rgba(168, 85, 247, 0.10));
        border: 1px solid rgba(129, 140, 248, 0.24);
        border-radius: 1rem;
        padding: 1rem 1.15rem;
        box-shadow: 0 14px 24px -20px rgba(79, 70, 229, 0.35);
    }
</style>

<div class="space-y-6 ocr-modern-page">
    <div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-indigo-50/40 p-3 shadow-sm">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
            <div class="rounded-xl border border-slate-200 bg-white p-4 min-h-[112px] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-[11px] uppercase tracking-wide text-slate-500 font-semibold">Total Runs</span>
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-indigo-100 text-indigo-600 text-sm"><i class="fas fa-layer-group"></i></span>
                </div>
                <p class="text-3xl font-bold text-slate-900 leading-none"><%= stats.total || 0 %></p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-4 min-h-[112px] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-[11px] uppercase tracking-wide text-slate-500 font-semibold">Success</span>
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-emerald-100 text-emerald-600 text-sm"><i class="fas fa-check"></i></span>
                </div>
                <p class="text-3xl font-bold text-emerald-600 leading-none"><%= stats.success_count || 0 %></p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-4 min-h-[112px] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-[11px] uppercase tracking-wide text-slate-500 font-semibold">Failed</span>
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-rose-100 text-rose-600 text-sm"><i class="fas fa-xmark"></i></span>
                </div>
                <p class="text-3xl font-bold text-rose-600 leading-none"><%= stats.failed_count || 0 %></p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-4 min-h-[112px] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-[11px] uppercase tracking-wide text-slate-500 font-semibold">Google</span>
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-blue-100 text-blue-600 text-sm"><i class="fab fa-google"></i></span>
                </div>
                <p class="text-3xl font-bold text-blue-600 leading-none"><%= stats.google_count || 0 %></p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-4 min-h-[112px] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-[11px] uppercase tracking-wide text-slate-500 font-semibold">Tesseract</span>
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-amber-100 text-amber-600 text-sm"><i class="fas fa-font"></i></span>
                </div>
                <p class="text-3xl font-bold text-amber-600 leading-none"><%= stats.tesseract_count || 0 %></p>
            </div>
        </div>
    </div>
</div>

<%
const headerButtons = [
    {
        text: 'Manage in Settings',
        href: '/admin/settings',
        icon: 'fas fa-cog',
        class: 'inline-flex items-center px-6 py-3 border border-transparent text-sm font-semibold rounded-xl text-white bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl'
    }
];

const columns = [
    { key: 'media_title', label: 'Media', sortable: false, type: 'custom', formatter: (item) => `
        <a href="/admin/ocr/${item.id}" class="text-indigo-600 hover:text-indigo-800 font-semibold">
            ${item.media_title || ('Media #' + item.media_id)}
        </a>
        <div class="text-xs text-slate-500 capitalize">${item.media_type || '-'} • OCR #${item.id}</div>
    ` },
    { key: 'provider', label: 'Provider', sortable: false, type: 'custom', formatter: (item) => `
        <span class="capitalize text-sm text-slate-700">${item.provider || '-'}</span>
    ` },
    { key: 'status', label: 'Status', sortable: false, type: 'custom', formatter: (item) => `
        <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-semibold ${item.status === 'success' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700'}">
            ${item.status || '-'}
        </span>
    ` },
    { key: 'language', label: 'Language', sortable: false, type: 'custom', formatter: (item) => `
        <span class="text-sm text-slate-700">${item.language || '-'}</span>
    ` },
    { key: 'confidence', label: 'Confidence', sortable: false, type: 'custom', formatter: (item) => `
        <span class="text-sm text-slate-700">${item.confidence !== null && item.confidence !== undefined ? Number(item.confidence).toFixed(2) + '%' : '-'}</span>
    ` },
    { key: 'processed_at', label: 'Processed', sortable: false, type: 'custom', formatter: (item) => `
        <span class="text-sm text-slate-700">${item.processed_at ? new Date(item.processed_at).toLocaleString() : '-'}</span>
    ` },
    { key: 'extracted_text', label: 'Preview', sortable: false, type: 'custom', formatter: (item) => `
        <span class="text-sm text-slate-600">${item.extracted_text ? `${item.extracted_text.substring(0, 120)}${item.extracted_text.length > 120 ? '...' : ''}` : '-'}</span>
    ` }
];

const actions = [
    {
        icon: () => 'fas fa-eye',
        title: () => 'View OCR',
        class: 'text-indigo-600 hover:text-indigo-900',
        onclick: (item) => `window.location.href='/admin/ocr/${item.id}'`
    }
];

const tableFilters = [];
%>

<div class="ocr-table-shell ocr-modern-page mt-2">
<%- include('../components/table', {
    title: title,
    data: data,
    headerButtons: headerButtons,
    columns: columns,
    actions: actions,
    pagination: pagination,
    search: filters.search || '',
    filters: tableFilters,
    showSearch: true,
    searchPlaceholder: 'Search media title or OCR text...',
    emptyIcon: 'fas fa-file-signature',
    emptyTitle: 'No OCR Records Found',
    emptyMessage: 'No OCR records are available yet.',
    emptySearchMessage: 'No OCR records match your search criteria.'
}) %>
</div>

<script>
    (function () {
        const params = new URLSearchParams(window.location.search);
        const toolbar = document.querySelector('.bg-gradient-to-r.from-slate-50.to-gray-50');
        if (!toolbar) return;
        const titleBlock = toolbar.querySelector('.flex.items-center.space-x-4');
        if (titleBlock) {
            const parent = titleBlock.closest('.bg-gradient-to-r.from-slate-50.to-gray-50');
            if (parent) {
                parent.classList.add('ocr-manager-head');
                parent.classList.add('mb-2');
            }
        }

        const controlsWrap = toolbar.querySelector('.flex.flex-col.sm\\:flex-row.space-y-3');
        if (!controlsWrap) return;
        controlsWrap.classList.add('lg:items-center');

        const providerSelectWrap = document.createElement('div');
        providerSelectWrap.className = 'relative';
        providerSelectWrap.innerHTML = `
            <select id="ocrProviderFilter" class="appearance-none min-w-[170px] px-4 py-3 pr-10 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 bg-white shadow-sm hover:shadow-md cursor-pointer">
                <option value="">All Providers</option>
                <option value="google">Google</option>
                <option value="tesseract">Tesseract</option>
            </select>
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                <i class="fas fa-chevron-down text-gray-400"></i>
            </div>
        `;

        const statusSelectWrap = document.createElement('div');
        statusSelectWrap.className = 'relative';
        statusSelectWrap.innerHTML = `
            <select id="ocrStatusFilter" class="appearance-none min-w-[160px] px-4 py-3 pr-10 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 bg-white shadow-sm hover:shadow-md cursor-pointer">
                <option value="">All Status</option>
                <option value="success">Success</option>
                <option value="failed">Failed</option>
            </select>
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                <i class="fas fa-chevron-down text-gray-400"></i>
            </div>
        `;

        controlsWrap.appendChild(providerSelectWrap);
        controlsWrap.appendChild(statusSelectWrap);

        const providerEl = document.getElementById('ocrProviderFilter');
        const statusEl = document.getElementById('ocrStatusFilter');
        const searchEl = document.getElementById('searchInput');

        providerEl.value = params.get('provider') || '';
        statusEl.value = params.get('status') || '';

        function applyFilters() {
            const q = new URLSearchParams();
            const searchVal = (searchEl && searchEl.value || '').trim();
            const providerVal = providerEl.value;
            const statusVal = statusEl.value;
            if (searchVal) q.set('search', searchVal);
            if (providerVal) q.set('provider', providerVal);
            if (statusVal) q.set('status', statusVal);
            window.location.href = `/admin/ocr?${q.toString()}`;
        }

        providerEl.addEventListener('change', applyFilters);
        statusEl.addEventListener('change', applyFilters);
    })();
</script>
