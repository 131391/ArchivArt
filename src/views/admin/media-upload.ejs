<!-- Upload Content Page -->
<div class="min-h-screen bg-slate-50">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-3 sm:py-4 lg:py-5 space-y-4">
        <div class="relative overflow-hidden bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-600 rounded-2xl p-5 sm:p-6 shadow-lg">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,.25),transparent_45%)]"></div>
            <div class="relative">
                <h2 class="text-xl sm:text-2xl font-semibold tracking-tight text-white">Create AR Media</h2>
                <p class="text-sm sm:text-base text-indigo-100 mt-1.5">Upload your media file and trigger image, then save as a new AR experience.</p>
            </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl p-2 shadow-sm w-full">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                <button type="button" class="media-tab active rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-left transition hover:bg-slate-100" data-type="video">
                    <div class="flex items-center gap-3">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-rose-500 to-pink-600 text-white shadow-sm">
                            <i class="fas fa-video text-sm"></i>
                        </span>
                        <span>
                            <span class="block text-sm font-semibold text-slate-900">Video</span>
                            <span class="block text-xs text-slate-500">MP4, AVI, MOV</span>
                        </span>
                    </div>
                </button>

                <button type="button" class="media-tab rounded-xl border border-slate-200 bg-white px-4 py-3 text-left transition hover:bg-slate-50" data-type="audio">
                    <div class="flex items-center gap-3">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600 text-white shadow-sm">
                            <i class="fas fa-music text-sm"></i>
                        </span>
                        <span>
                            <span class="block text-sm font-semibold text-slate-900">Audio</span>
                            <span class="block text-xs text-slate-500">MP3, WAV, AAC</span>
                        </span>
                    </div>
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-5 xl:gap-6 items-start">
            <div class="space-y-5">
                <%- include('../components/modern-upload-card') %>
                <div class="hidden xl:block">
                    <%- include('../components/tips-card') %>
                </div>
            </div>

            <div class="space-y-5 xl:sticky xl:top-4">
                <%- include('../components/modern-details-form') %>
            </div>
        </div>
    </div>
</div>

<style>
.media-tab.active {
    border-color: #4f46e5 !important;
    background: linear-gradient(180deg, #f5f3ff 0%, #eef2ff 100%) !important;
    box-shadow: 0 0 0 2px rgba(79, 70, 229, 0.22), 0 12px 24px -16px rgba(79, 70, 229, 0.55) !important;
}

#drop-zone.dragover,
#scanning-image-drop-zone.dragover {
    border-color: #4f46e5 !important;
    background-color: #eef2ff !important;
}

.media-tab {
    transition: all 180ms ease;
}

.media-tab:hover {
    transform: translateY(-1px);
}

.media-tab[data-type="video"].active {
    border-color: #e11d48 !important;
    background: linear-gradient(180deg, #fff1f2 0%, #ffe4e6 100%) !important;
    box-shadow: 0 0 0 2px rgba(225, 29, 72, 0.2), 0 12px 24px -16px rgba(225, 29, 72, 0.45) !important;
}

.media-tab[data-type="audio"].active {
    border-color: #059669 !important;
    background: linear-gradient(180deg, #ecfdf5 0%, #d1fae5 100%) !important;
    box-shadow: 0 0 0 2px rgba(5, 150, 105, 0.2), 0 12px 24px -16px rgba(5, 150, 105, 0.45) !important;
}
</style>
