<div class="space-y-6">
    <section class="rounded-2xl border border-slate-200 bg-gradient-to-r from-indigo-600 via-purple-600 to-violet-600 px-5 py-6 shadow-sm sm:px-6 lg:px-8">
        <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
            <div class="flex items-center gap-4 sm:gap-5">
                <div class="relative">
                    <img
                        id="profileImage"
                        class="h-20 w-20 rounded-2xl border-2 border-white/80 object-cover shadow-lg sm:h-24 sm:w-24"
                        src="<%= user.profile_picture || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=8b5cf6&color=ffffff&size=128&bold=true' %>"
                        alt="<%= user.name %>"
                    >
                    <span class="absolute -bottom-1 -right-1 h-5 w-5 rounded-full border-2 border-white bg-emerald-400"></span>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white sm:text-3xl"><%= user.name %></h1>
                    <p class="mt-1 text-sm text-indigo-100 sm:text-base"><%= user.email %></p>
                    <span class="mt-3 inline-flex items-center rounded-full border border-white/25 bg-white/15 px-3 py-1.5 text-xs font-semibold text-white backdrop-blur-sm">
                        <i class="fas fa-shield-alt mr-2 text-indigo-100"></i>
                        <%= (user.role_display_name || user.role).charAt(0).toUpperCase() + (user.role_display_name || user.role).slice(1) %>
                    </span>
                </div>
            </div>
            <div class="rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-left md:text-right">
                <p class="text-xs uppercase tracking-wide text-indigo-100">Member Since</p>
                <p class="mt-1 text-lg font-semibold text-white">
                    <% if (user && user.created_at) { %>
                        <%= new Date(user.created_at).toLocaleDateString() %>
                    <% } else { %>
                        N/A
                    <% } %>
                </p>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-6 xl:grid-cols-3">
        <div class="xl:col-span-2 space-y-6">
            <div class="admin-surface-card">
                <div class="admin-surface-header">
                    <h2 class="text-lg font-semibold text-slate-900 flex items-center">
                        <i class="fas fa-user-edit mr-2 text-indigo-600"></i>
                        Profile Information
                    </h2>
                </div>
                <div class="p-5 sm:p-6">
                    <form action="/admin/profile" method="POST" class="space-y-5">
                        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                            <div class="group">
                                <label for="name" class="mb-2 block text-sm font-medium text-slate-700">Full Name</label>
                                <div class="relative">
                                    <input
                                        type="text"
                                        name="name"
                                        id="name"
                                        class="w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-2.5 text-slate-900 shadow-sm transition-all duration-200 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-100"
                                        value="<%= user.name %>"
                                        required
                                    >
                                    <span class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 group-hover:text-indigo-500">
                                        <i class="fas fa-user"></i>
                                    </span>
                                </div>
                            </div>
                            <div class="group">
                                <label for="email" class="mb-2 block text-sm font-medium text-slate-700">Email Address</label>
                                <div class="relative">
                                    <input
                                        type="email"
                                        name="email"
                                        id="email"
                                        class="w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-2.5 text-slate-900 shadow-sm transition-all duration-200 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-100"
                                        value="<%= user.email %>"
                                        required
                                    >
                                    <span class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 group-hover:text-indigo-500">
                                        <i class="fas fa-envelope"></i>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                            <p class="mb-3 text-sm font-semibold text-slate-700">Account Details</p>
                            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                                <div class="rounded-lg border border-violet-200 bg-violet-50 px-3 py-2">
                                    <p class="text-[11px] uppercase tracking-wide text-violet-600">Role</p>
                                    <p class="mt-1 text-sm font-semibold text-violet-900"><%= user.role_display_name || user.role %></p>
                                </div>
                                <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2">
                                    <p class="text-[11px] uppercase tracking-wide text-emerald-600">Status</p>
                                    <p class="mt-1 text-sm font-semibold text-emerald-900">Active</p>
                                </div>
                            </div>
                        </div>

                        <button
                            type="submit"
                            class="inline-flex w-full items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:from-indigo-700 hover:to-violet-700"
                        >
                            <i class="fas fa-save mr-2"></i>
                            Update Profile
                        </button>
                    </form>
                </div>
            </div>

            <div class="admin-surface-card">
                <div class="admin-surface-header">
                    <h2 class="text-lg font-semibold text-slate-900 flex items-center">
                        <i class="fas fa-key mr-2 text-rose-600"></i>
                        Change Password
                    </h2>
                </div>
                <div class="p-5 sm:p-6">
                    <form action="/admin/change-password" method="POST" class="space-y-5">
                        <div class="group">
                            <label for="current_password" class="mb-2 block text-sm font-medium text-slate-700">Current Password</label>
                            <div class="relative">
                                <input
                                    type="password"
                                    name="current_password"
                                    id="current_password"
                                    class="w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-2.5 text-slate-900 shadow-sm transition-all duration-200 focus:border-rose-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-100"
                                    required
                                >
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3">
                                    <i class="fas fa-eye cursor-pointer text-slate-400 transition-colors hover:text-rose-500" onclick="togglePassword('current_password')"></i>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                            <div class="group">
                                <label for="new_password" class="mb-2 block text-sm font-medium text-slate-700">New Password</label>
                                <div class="relative">
                                    <input
                                        type="password"
                                        name="new_password"
                                        id="new_password"
                                        class="w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-2.5 text-slate-900 shadow-sm transition-all duration-200 focus:border-emerald-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-100"
                                        required
                                    >
                                    <div class="absolute inset-y-0 right-0 flex items-center pr-3">
                                        <i class="fas fa-eye cursor-pointer text-slate-400 transition-colors hover:text-emerald-500" onclick="togglePassword('new_password')"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="group">
                                <label for="confirm_password" class="mb-2 block text-sm font-medium text-slate-700">Confirm New Password</label>
                                <div class="relative">
                                    <input
                                        type="password"
                                        name="confirm_password"
                                        id="confirm_password"
                                        class="w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-2.5 text-slate-900 shadow-sm transition-all duration-200 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-100"
                                        required
                                    >
                                    <div class="absolute inset-y-0 right-0 flex items-center pr-3">
                                        <i class="fas fa-eye cursor-pointer text-slate-400 transition-colors hover:text-indigo-500" onclick="togglePassword('confirm_password')"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
                            <h4 class="mb-2 flex items-center text-sm font-semibold text-amber-900">
                                <i class="fas fa-shield-alt mr-2 text-amber-600"></i>
                                Password Requirements
                            </h4>
                            <ul class="space-y-1 text-xs text-amber-800">
                                <li class="flex items-center"><i class="fas fa-check mr-2 text-emerald-600"></i>At least 8 characters</li>
                                <li class="flex items-center"><i class="fas fa-check mr-2 text-emerald-600"></i>Include uppercase and lowercase letters</li>
                                <li class="flex items-center"><i class="fas fa-check mr-2 text-emerald-600"></i>Include at least one number</li>
                            </ul>
                        </div>

                        <button
                            type="submit"
                            class="inline-flex w-full items-center justify-center rounded-xl bg-gradient-to-r from-rose-600 to-pink-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:from-rose-700 hover:to-pink-700"
                        >
                            <i class="fas fa-key mr-2"></i>
                            Change Password
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="admin-surface-card">
                <div class="admin-surface-header">
                    <h2 class="text-lg font-semibold text-slate-900 flex items-center">
                        <i class="fas fa-camera mr-2 text-indigo-600"></i>
                        Profile Picture
                    </h2>
                </div>
                <div class="p-5 sm:p-6">
                    <div class="flex items-start gap-4">
                        <img
                            id="currentProfileImage"
                            class="h-20 w-20 rounded-2xl border border-slate-200 object-cover shadow-sm"
                            src="<%= user.profile_picture || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=6366f1&color=ffffff&size=80&bold=true' %>"
                            alt="Current Profile Picture"
                            data-original-src="<%= user.profile_picture || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=6366f1&color=ffffff&size=80&bold=true' %>"
                        >
                        <div class="min-w-0 flex-1">
                            <h3 class="text-sm font-semibold text-slate-900">Upload New Photo</h3>
                            <p class="mt-1 text-xs text-slate-500">JPEG, PNG, or WebP. Max size 5MB.</p>
                        </div>
                    </div>

                    <div class="mt-5 flex flex-wrap items-center gap-2.5">
                        <label for="profilePictureInput" class="cursor-pointer inline-flex items-center rounded-lg bg-indigo-600 px-3.5 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">
                            <i class="fas fa-upload mr-2"></i>
                            Choose File
                        </label>
                        <input type="file" id="profilePictureInput" accept="image/jpeg,image/jpg,image/png,image/webp" class="hidden">

                        <button id="uploadProfilePicture" class="inline-flex items-center rounded-lg bg-emerald-600 px-3.5 py-2 text-sm font-medium text-white transition hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-50" disabled>
                            <i class="fas fa-save mr-2"></i>
                            Upload
                        </button>

                        <button id="removeProfilePicture" class="hidden inline-flex items-center rounded-lg bg-rose-600 px-3.5 py-2 text-sm font-medium text-white transition hover:bg-rose-700">
                            <i class="fas fa-trash mr-2"></i>
                            Remove
                        </button>
                    </div>

                    <div id="uploadProgress" class="hidden mt-4">
                        <div class="h-2 rounded-full bg-slate-200">
                            <div id="progressBar" class="h-2 w-0 rounded-full bg-gradient-to-r from-indigo-500 to-violet-600 transition-all duration-300"></div>
                        </div>
                        <p id="progressText" class="mt-2 text-xs text-slate-600">Uploading...</p>
                    </div>
                </div>
            </div>

            <div class="admin-surface-card">
                <div class="admin-surface-header">
                    <h2 class="text-lg font-semibold text-slate-900 flex items-center">
                        <i class="fas fa-history mr-2 text-teal-600"></i>
                        Recent Activity
                    </h2>
                </div>
                <div class="p-5 sm:p-6">
                    <div class="space-y-3">
                        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-3">
                            <p class="text-sm font-semibold text-slate-900">Logged in successfully</p>
                            <p class="mt-1 text-xs text-slate-500">2 hours ago</p>
                        </div>
                        <div class="rounded-xl border border-blue-200 bg-blue-50 p-3">
                            <p class="text-sm font-semibold text-slate-900">Uploaded new media</p>
                            <p class="mt-1 text-xs text-slate-500">1 day ago</p>
                        </div>
                        <div class="rounded-xl border border-violet-200 bg-violet-50 p-3">
                            <p class="text-sm font-semibold text-slate-900">Updated profile information</p>
                            <p class="mt-1 text-xs text-slate-500">3 days ago</p>
                        </div>
                        <div class="rounded-xl border border-amber-200 bg-amber-50 p-3">
                            <p class="text-sm font-semibold text-slate-900">Changed password</p>
                            <p class="mt-1 text-xs text-slate-500">1 week ago</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
