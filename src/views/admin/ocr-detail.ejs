<div class="min-h-screen bg-slate-50">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-4 space-y-4">
        <div class="bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-600 rounded-2xl p-5 shadow-lg text-white">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                <div>
                    <p class="text-indigo-100 text-xs uppercase tracking-wide">OCR Result Details</p>
                    <h1 class="text-2xl font-semibold mt-1"><%= record.media_title || ('Media #' + record.media_id) %></h1>
                    <p class="text-indigo-100 text-sm mt-1">Record #<%= record.id %> • Media #<%= record.media_id %></p>
                </div>
                <div class="flex items-center gap-2">
                    <a href="/admin/ocr" class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-white/35 bg-white/10 text-sm font-semibold text-white hover:bg-white/20 transition-colors">
                        <i class="fas fa-arrow-left mr-2"></i>
                        Back to OCR List
                    </a>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="lg:col-span-2 space-y-4">
                <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
                    <div class="flex items-center justify-between mb-3">
                        <h2 class="text-base font-semibold text-slate-900">Extracted Text</h2>
                        <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold <%= record.status === 'success' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                            <%= record.status || '-' %>
                        </span>
                    </div>
                    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <% if (record.extracted_text) { %>
                            <pre class="whitespace-pre-wrap break-words text-sm text-slate-700 font-sans"><%= record.extracted_text %></pre>
                        <% } else { %>
                            <p class="text-sm text-slate-500">No extracted text available.</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="space-y-4">
                <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
                    <h2 class="text-base font-semibold text-slate-900 mb-3">Metadata</h2>
                    <dl class="space-y-3 text-sm">
                        <div class="flex items-start justify-between gap-4">
                            <dt class="text-slate-500">Provider</dt>
                            <dd class="font-semibold text-slate-800 capitalize"><%= record.provider || '-' %></dd>
                        </div>
                        <div class="flex items-start justify-between gap-4">
                            <dt class="text-slate-500">Language</dt>
                            <dd class="font-semibold text-slate-800"><%= record.language || '-' %></dd>
                        </div>
                        <div class="flex items-start justify-between gap-4">
                            <dt class="text-slate-500">Confidence</dt>
                            <dd class="font-semibold text-slate-800">
                                <%= record.confidence !== null && record.confidence !== undefined ? Number(record.confidence).toFixed(2) + '%' : '-' %>
                            </dd>
                        </div>
                        <div class="flex items-start justify-between gap-4">
                            <dt class="text-slate-500">Processed At</dt>
                            <dd class="font-semibold text-slate-800 text-right"><%= record.processed_at ? new Date(record.processed_at).toLocaleString() : '-' %></dd>
                        </div>
                    </dl>
                </div>

                <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm">
                    <h2 class="text-base font-semibold text-slate-900 mb-3">Source Media</h2>
                    <dl class="space-y-3 text-sm">
                        <div class="flex items-start justify-between gap-4">
                            <dt class="text-slate-500">Media ID</dt>
                            <dd class="font-semibold text-slate-800"><%= record.media_id %></dd>
                        </div>
                        <div class="flex items-start justify-between gap-4">
                            <dt class="text-slate-500">Type</dt>
                            <dd class="font-semibold text-slate-800 capitalize"><%= record.media_type || '-' %></dd>
                        </div>
                        <div class="flex items-start justify-between gap-4">
                            <dt class="text-slate-500">Status</dt>
                            <dd class="font-semibold text-slate-800"><%= record.media_is_active ? 'Active' : 'Inactive' %></dd>
                        </div>
                    </dl>

                    <% if (record.scanning_image) { %>
                        <div class="mt-4">
                            <p class="text-xs text-slate-500 mb-2">Scanning image</p>
                            <img src="<%= record.scanning_image %>" alt="Scanning image" class="w-full rounded-xl border border-slate-200 object-cover max-h-44">
                        </div>
                    <% } %>

                    <% if (record.error_message) { %>
                        <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-3">
                            <p class="text-xs text-rose-700 font-semibold mb-1">Error Message</p>
                            <p class="text-xs text-rose-700"><%= record.error_message %></p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
