<div class="flex-1 min-h-screen bg-gray-50">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-6">
        <div class="mb-3">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">OCR Details</h1>
                    <p class="mt-1 text-sm text-gray-600">View OCR extraction result and source media context</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 w-full sm:w-auto">
                    <a href="/admin/ocr" class="inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                        <i class="fas fa-arrow-left mr-2"></i>
                        Back to OCR List
                    </a>
                    <% if (record.media_id) { %>
                        <a href="/admin/media/view/<%= record.media_id %>" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
                            <i class="fas fa-images mr-2"></i>
                            View Source Media
                        </a>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-gradient-to-br from-white to-gray-50 rounded-xl shadow-lg border border-gray-200 overflow-hidden">
                <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-4">
                    <h2 class="text-xl font-bold text-white flex items-center">
                        <div class="w-8 h-8 bg-white bg-opacity-20 rounded-lg flex items-center justify-center mr-3">
                            <i class="fas fa-file-signature text-white text-sm"></i>
                        </div>
                        Extracted Text
                    </h2>
                    <p class="text-indigo-100 text-sm mt-1">OCR Record #<%= record.id %></p>
                </div>
                <div class="p-6">
                    <div class="bg-white rounded-xl p-4 border border-gray-200 min-h-[280px]">
                        <% if (record.extracted_text) { %>
                            <pre class="whitespace-pre-wrap break-words text-sm text-gray-700 font-sans"><%= record.extracted_text %></pre>
                        <% } else { %>
                            <p class="text-sm text-gray-500 italic">No extracted text available for this record.</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-white to-blue-50 rounded-xl shadow-lg border border-blue-100 overflow-hidden">
                <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4">
                    <h2 class="text-xl font-bold text-white flex items-center">
                        <div class="w-8 h-8 bg-white bg-opacity-20 rounded-lg flex items-center justify-center mr-3">
                            <i class="fas fa-info-circle text-white text-sm"></i>
                        </div>
                        OCR Information
                    </h2>
                    <p class="text-blue-100 text-sm mt-1">Provider, confidence and processing metadata</p>
                </div>
                <div class="p-6 space-y-4">
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Status</span>
                        <span class="inline-flex px-3 py-1 rounded-full text-xs font-semibold <%= record.status === 'success' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                            <%= record.status || '-' %>
                        </span>
                    </div>
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Provider</span>
                        <span class="text-sm font-semibold text-gray-900 capitalize"><%= record.provider || '-' %></span>
                    </div>
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Language</span>
                        <span class="text-sm font-semibold text-gray-900"><%= record.language || '-' %></span>
                    </div>
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Confidence</span>
                        <span class="text-sm font-semibold text-gray-900">
                            <%= record.confidence !== null && record.confidence !== undefined ? Number(record.confidence).toFixed(2) + '%' : '-' %>
                        </span>
                    </div>
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Processed At</span>
                        <span class="text-sm font-semibold text-gray-900"><%= record.processed_at ? new Date(record.processed_at).toLocaleString() : '-' %></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-gradient-to-br from-white to-green-50 rounded-xl shadow-lg border border-green-200 overflow-hidden">
                <div class="bg-gradient-to-r from-green-600 to-emerald-600 px-6 py-4">
                    <h2 class="text-xl font-bold text-white flex items-center">
                        <div class="w-8 h-8 bg-white bg-opacity-20 rounded-lg flex items-center justify-center mr-3">
                            <i class="fas fa-qrcode text-white text-sm"></i>
                        </div>
                        Source Scanning Image
                    </h2>
                </div>
                <div class="p-6">
                    <% if (record.scanning_image) { %>
                        <img src="<%= record.scanning_image %>" alt="Scanning image" class="w-full h-72 object-contain rounded-lg border border-gray-200 bg-white">
                    <% } else { %>
                        <div class="w-full h-72 rounded-lg border border-dashed border-gray-300 bg-gray-50 flex items-center justify-center text-gray-500 text-sm">
                            Scanning image not available
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="bg-gradient-to-br from-white to-gray-50 rounded-xl shadow-lg border border-gray-200 overflow-hidden">
                <div class="bg-gradient-to-r from-gray-700 to-slate-700 px-6 py-4">
                    <h2 class="text-xl font-bold text-white flex items-center">
                        <div class="w-8 h-8 bg-white bg-opacity-20 rounded-lg flex items-center justify-center mr-3">
                            <i class="fas fa-database text-white text-sm"></i>
                        </div>
                        Source Media Metadata
                    </h2>
                </div>
                <div class="p-6 space-y-4">
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Media ID</span>
                        <span class="text-sm font-semibold text-gray-900"><%= record.media_id %></span>
                    </div>
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Title</span>
                        <span class="text-sm font-semibold text-gray-900"><%= record.media_title || '-' %></span>
                    </div>
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Media Type</span>
                        <span class="text-sm font-semibold text-gray-900 capitalize"><%= record.media_type || '-' %></span>
                    </div>
                    <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Media Status</span>
                        <span class="text-sm font-semibold text-gray-900"><%= record.media_is_active ? 'Active' : 'Inactive' %></span>
                    </div>
                    <% if (record.error_message) { %>
                        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
                            <p class="text-xs font-semibold uppercase tracking-wide text-red-700 mb-1">Error Message</p>
                            <p class="text-sm text-red-700"><%= record.error_message %></p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
