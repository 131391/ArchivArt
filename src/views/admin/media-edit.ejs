<div class="flex-1 min-h-screen bg-slate-50">
    <div class="w-full px-4 sm:px-6 lg:px-8 py-5 space-y-5">
        <div class="admin-surface-card overflow-hidden">
            <div class="admin-surface-header bg-gradient-to-r from-indigo-50 via-violet-50 to-fuchsia-50">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                    <div class="min-w-0 flex items-start gap-3">
                        <div class="w-11 h-11 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 text-white flex items-center justify-center shadow-sm">
                            <i class="fas fa-pen-to-square text-sm"></i>
                        </div>
                        <div>
                            <h1 class="text-2xl font-bold text-slate-900">Edit Media</h1>
                            <p class="mt-1 text-sm text-slate-600">Update media details, scanning image, and visibility settings</p>
                        </div>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <a href="/admin/media/view/<%= media.id %>" class="inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-semibold rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                            <i class="fas fa-arrow-left mr-2"></i>
                            Back to View
                        </a>
                        <a href="/admin/media" class="inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-semibold rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                            <i class="fas fa-list mr-2"></i>
                            Media List
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-12 gap-5">
            <div class="xl:col-span-5 space-y-5">
                <div class="admin-surface-card admin-surface-card-hover overflow-hidden">
                    <div class="admin-surface-header">
                        <h3 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
                            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600">
                                <i class="fas fa-<%= media.media_type === 'video' ? 'video' : media.media_type === 'audio' ? 'music' : 'image' %> text-xs"></i>
                            </span>
                            Current Media
                        </h3>
                        <p class="text-sm text-slate-600">Preview of the uploaded media file</p>
                    </div>
                    <div class="p-4 sm:p-5">
                        <div class="rounded-xl bg-gradient-to-br from-slate-900 via-slate-800 to-black p-4">
                            <% if (media.media_type === 'video') { %>
                                <video 
                                    class="w-full h-56 bg-black rounded-lg" 
                                    controls 
                                    preload="metadata"
                                    poster="<%= scanningImageUrl(media.scanning_image) %>"
                                >
                                    <source src="<%= mediaUrl(media.file_path) %>" type="<%= media.mime_type %>">
                                    Your browser does not support the video tag.
                                </video>
                            <% } else if (media.media_type === 'audio') { %>
                                <div class="rounded-lg p-4 text-center bg-white/5 border border-white/10">
                                    <div class="w-14 h-14 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
                                        <i class="fas fa-music text-white text-xl"></i>
                                    </div>
                                    <audio 
                                        class="w-full" 
                                        controls 
                                        preload="metadata"
                                    >
                                        <source src="<%= mediaUrl(media.file_path) %>" type="<%= media.mime_type %>">
                                        Your browser does not support the audio tag.
                                    </audio>
                                </div>
                            <% } else { %>
                                <img 
                                    src="<%= mediaUrl(media.file_path) %>" 
                                    alt="<%= media.title %>" 
                                    class="w-full h-56 object-cover rounded-lg"
                                >
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="admin-surface-card admin-surface-card-hover">
                    <div class="admin-surface-header">
                        <h3 class="text-base font-semibold text-slate-900 flex items-center gap-2">
                            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-slate-100 text-slate-600">
                                <i class="fas fa-chart-bar text-xs"></i>
                            </span>
                            Media Stats
                        </h3>
                    </div>
                    <div class="p-4 sm:p-5 space-y-3 text-sm">
                        <div class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2.5">
                            <span class="text-slate-600">File Size</span>
                            <span class="font-semibold text-slate-900"><%= (media.file_size / 1024 / 1024).toFixed(2) %> MB</span>
                        </div>
                        <div class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2.5">
                            <span class="text-slate-600">MIME Type</span>
                            <span class="font-semibold text-slate-900 font-mono text-xs sm:text-sm"><%= media.mime_type %></span>
                        </div>
                        <div class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2.5">
                            <span class="text-slate-600">Status</span>
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold <%= media.is_active ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                                <i class="fas fa-<%= media.is_active ? 'check' : 'times' %> mr-1"></i>
                                <%= media.is_active ? 'Active' : 'Inactive' %>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="xl:col-span-7">
                <div class="admin-surface-card overflow-hidden">
                    <div class="admin-surface-header">
                        <h3 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
                            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-violet-100 text-violet-600">
                                <i class="fas fa-sliders text-xs"></i>
                            </span>
                            Edit Details
                        </h3>
                        <p class="text-sm text-slate-600">Modify metadata and upload a new scanning image when needed</p>
                    </div>
                    <div class="p-4 sm:p-6">
                        <form id="edit-media-form" class="space-y-5">
                            <input type="hidden" id="media-id" value="<%= media.id %>">
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="md:col-span-2">
                                    <label for="edit-title" class="block text-sm font-semibold text-slate-700 mb-1.5">Title *</label>
                                    <input type="text" id="edit-title" name="title" value="<%= media.title %>" placeholder="Enter media title" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-indigo-500 focus:outline-none bg-white" required>
                                </div>
                                
                                <div class="md:col-span-2">
                                    <label for="edit-description" class="block text-sm font-semibold text-slate-700 mb-1.5">Description</label>
                                    <textarea id="edit-description" name="description" rows="4" placeholder="Enter media description" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-indigo-500 focus:outline-none bg-white resize-y"><%= media.description || '' %></textarea>
                                </div>

                                <div>
                                    <label for="edit-media-type" class="block text-sm font-semibold text-slate-700 mb-1.5">Media Type *</label>
                                    <select id="edit-media-type" name="media_type" class="w-full border border-slate-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-indigo-500 focus:outline-none bg-white" required>
                                        <option value="image" <%= media.media_type === 'image' ? 'selected' : '' %>>Image</option>
                                        <option value="video" <%= media.media_type === 'video' ? 'selected' : '' %>>Video</option>
                                        <option value="audio" <%= media.media_type === 'audio' ? 'selected' : '' %>>Audio</option>
                                    </select>
                                </div>

                                <div class="flex items-end">
                                    <label class="inline-flex items-center w-full rounded-lg border border-slate-200 px-3 py-2.5 bg-slate-50">
                                        <input type="checkbox" id="edit-is-active" name="is_active" <%= media.is_active ? 'checked' : '' %> class="rounded border-slate-300 text-indigo-600 shadow-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50">
                                        <span class="ml-2 text-sm text-slate-700 font-medium">Active (visible to users)</span>
                                    </label>
                                </div>
                            </div>

                            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3.5 sm:p-4 space-y-3">
                                <div>
                                    <label for="edit-scanning-image" class="block text-sm font-semibold text-slate-700">
                                        <i class="fas fa-image mr-1"></i>Scanning Image
                                    </label>
                                    <p class="text-xs text-slate-500 mt-0.5">Current scanning image (optional to change)</p>
                                </div>
                                
                                <div class="bg-white rounded-lg p-3 border border-slate-200">
                                    <div class="flex items-center gap-3">
                                        <div class="flex-shrink-0">
                                            <img src="<%= scanningImageUrl(media.scanning_image) %>" alt="Current scanning image" class="h-12 w-12 rounded object-cover">
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-semibold text-slate-900">Current Scanning Image</p>
                                            <p class="text-xs text-slate-500">Upload below if you want to replace it</p>
                                        </div>
                                    </div>
                                </div>

                                <input type="file" id="edit-scanning-image-input" accept="image/*" class="hidden">
                                <div class="border-2 border-dashed border-slate-300 rounded-lg p-4 text-center hover:border-indigo-400 hover:bg-indigo-50/50 transition-all duration-200 cursor-pointer bg-white" id="edit-scanning-image-drop-zone">
                                    <div class="space-y-2">
                                        <div class="mx-auto w-9 h-9 bg-indigo-50 rounded-full flex items-center justify-center">
                                            <i class="fas fa-upload text-sm text-indigo-500"></i>
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold text-slate-900">Change Scanning Image</p>
                                            <p class="text-xs text-slate-600">Click or drag image here</p>
                                            <p class="text-xs text-slate-500 mt-1">JPEG, PNG, GIF, WebP (Max: 10MB)</p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div id="edit-scanning-image-preview" class="hidden">
                                    <div class="bg-white rounded-lg p-3 border border-slate-200">
                                        <div class="flex items-center gap-3">
                                            <div class="flex-shrink-0">
                                                <img id="edit-scanning-image-thumbnail" class="h-12 w-12 rounded object-cover" src="" alt="New scanning image preview">
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <p class="text-sm font-semibold text-slate-900 truncate" id="edit-scanning-image-name"></p>
                                                <p class="text-xs text-slate-500" id="edit-scanning-image-size"></p>
                                            </div>
                                            <button type="button" class="text-rose-500 hover:text-rose-700 p-1.5 rounded-md hover:bg-rose-50 transition-colors" id="remove-edit-scanning-image">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex flex-col sm:flex-row gap-3 pt-2">
                                <button type="submit" id="edit-submit-button" class="sm:flex-1 bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-2.5 px-4 rounded-lg hover:from-indigo-700 hover:to-purple-700 transition-all flex items-center justify-center shadow-sm">
                                    <i class="fas fa-save mr-2"></i>
                                    <span id="edit-submit-text">Update Media</span>
                                </button>
                                <button type="button" id="edit-cancel-button" class="px-4 py-2.5 border border-slate-300 text-sm font-semibold rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Media Edit JavaScript - loaded from admin layout -->
