                                        <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-blue-600 mr-2" id="usersLoader"></div>
                                        Loading...
                                    </div>
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            <!-- System Health -->
            <div class="admin-surface-card admin-surface-card-hover overflow-hidden bg-white/95">
                <div class="p-5">
                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <div class="w-11 h-11 bg-gradient-to-r from-red-500 to-pink-600 rounded-xl flex items-center justify-center">
                                <i class="fas fa-heartbeat text-white"></i>
                            </div>
                        </div>
                        <div class="ml-3 w-0 flex-1">
                            <dl>
                                <dt class="text-xs font-semibold tracking-wide text-slate-500 uppercase truncate">System Health</dt>
                                <dd class="text-2xl font-bold text-green-600" id="systemHealth">
                                    <span class="inline-flex items-center">
                                        <div class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></div>
                                        Good
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-5">
            <!-- Roles Management -->
            <div class="admin-surface-card admin-surface-card-hover">
                <div class="px-5 py-5">
                    <div class="flex items-center mb-4">
                        <div class="w-10 h-10 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center mr-3">
                            <i class="fas fa-users-cog text-white"></i>
                        </div>
                        <h3 class="text-lg font-semibold text-slate-900">Roles Management</h3>
                    </div>
                    <p class="text-sm text-slate-600 mb-4">Create and manage user roles and their permissions</p>
                    <div class="space-y-3">
                        <button onclick="window.location.href='/admin/rbac/roles'" class="w-full flex items-center justify-between px-4 py-3 border border-slate-300 rounded-xl shadow-sm text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200">
                            <span class="flex items-center">
                                <i class="fas fa-cog mr-2"></i>
                                Manage Roles
                            </span>
                            <i class="fas fa-arrow-right"></i>
                        </button>
                        <button onclick="createRole()" class="w-full flex items-center justify-between px-4 py-3 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200">
                            <span class="flex items-center">
                                <i class="fas fa-plus mr-2"></i>
                                Create New Role
                            </span>
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Permissions Management -->
            <div class="admin-surface-card admin-surface-card-hover">
                <div class="px-5 py-5">
                    <div class="flex items-center mb-4">
                        <div class="w-10 h-10 bg-gradient-to-r from-green-500 to-emerald-600 rounded-xl flex items-center justify-center mr-3">
                            <i class="fas fa-key text-white"></i>
                        </div>
                        <h3 class="text-lg font-semibold text-slate-900">Permissions Management</h3>
                    </div>
                    <p class="text-sm text-slate-600 mb-4">Define and manage system permissions and access controls</p>
                    <div class="space-y-3">
                        <button onclick="window.location.href='/admin/rbac/permissions'" class="w-full flex items-center justify-between px-4 py-3 border border-slate-300 rounded-xl shadow-sm text-sm font-medium text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-200">
                            <span class="flex items-center">
                                <i class="fas fa-cog mr-2"></i>
