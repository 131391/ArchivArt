                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <div class="w-11 h-11 bg-gradient-to-r from-green-500 to-emerald-600 rounded-xl flex items-center justify-center">
                                <i class="fas fa-key text-white"></i>
                            </div>
                        </div>
                        <div class="ml-3 w-0 flex-1">
                            <dl>
                                <dt class="text-xs font-semibold tracking-wide text-slate-500 uppercase truncate">Total Permissions</dt>
