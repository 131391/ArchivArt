            </div>

            <!-- Active Users -->
            <div class="admin-surface-card admin-surface-card-hover overflow-hidden bg-white/95">
                <div class="p-5">
                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <div class="w-11 h-11 bg-gradient-to-r from-blue-500 to-cyan-600 rounded-xl flex items-center justify-center">
