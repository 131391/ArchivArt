        <!-- Recent Activity -->
        <div class="admin-surface-card">
            <div class="px-5 py-5">
                <div class="flex items-center mb-4">
                    <div class="w-10 h-10 bg-gradient-to-r from-blue-500 to-cyan-600 rounded-xl flex items-center justify-center mr-3">
                        <i class="fas fa-history text-white"></i>
                    </div>
                    <h3 class="text-lg font-semibold text-slate-900">Recent Activity</h3>
                </div>
                <div class="flow-root">
                    <ul class="-mb-8" id="recentActivity">
                        <li class="relative pb-8">
                            <div class="relative flex space-x-3">
                                <div>
                                    <span class="h-10 w-10 rounded-full bg-gradient-to-r from-green-500 to-emerald-600 flex items-center justify-center ring-8 ring-white shadow-lg">
                                        <i class="fas fa-check text-white text-sm"></i>
                                    </span>
                                </div>
                                <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">RBAC system initialized successfully</p>
                                        <p class="text-xs text-gray-500">All roles and permissions have been loaded</p>
                                    </div>
                                    <div class="text-right text-sm whitespace-nowrap text-gray-500">
                                        <time datetime="2024-01-01" class="font-medium">Just now</time>
                                    </div>
                                </div>
                            </div>
                        </li>
                        <li class="relative pb-8">
                            <div class="relative flex space-x-3">
                                <div>
                                    <span class="h-10 w-10 rounded-full bg-gradient-to-r from-blue-500 to-indigo-600 flex items-center justify-center ring-8 ring-white shadow-lg">
                                        <i class="fas fa-database text-white text-sm"></i>
                                    </span>
                                </div>
                                <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">Database connection established</p>
                                        <p class="text-xs text-gray-500">All RBAC tables are accessible</p>
                                    </div>
                                    <div class="text-right text-sm whitespace-nowrap text-gray-500">
                                        <time datetime="2024-01-01" class="font-medium">Just now</time>
                                    </div>
                                </div>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Dashboard functions
function refreshDashboard() {
    loadDashboardStats();
    showSuccessToast('Dashboard refreshed');
}

function createRole() {
    window.location.href = '/admin/rbac/roles';
}

function createPermission() {
    window.location.href = '/admin/rbac/permissions';
}

function loadDashboardStats() {
    // Load RBAC dashboard stats
    fetch('/admin/api/rbac/dashboard')
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Hide loader and show data
                document.getElementById('rolesLoader').style.display = 'none';
                document.getElementById('permissionsLoader').style.display = 'none';
                
                document.getElementById('totalRoles').innerHTML = data.data.totalRoles || 0;
                document.getElementById('totalPermissions').innerHTML = data.data.totalPermissions || 0;
            } else {
                console.error('RBAC dashboard API returned error:', data.message);
                loadIndividualStats();
            }
        })
        .catch(error => {
            console.error('Error loading RBAC stats:', error);
            // Fallback to individual API calls
            loadIndividualStats();
        });

    // Load active users count
    fetch('/admin/users/data')
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Hide loader and show data
                document.getElementById('usersLoader').style.display = 'none';
                
                const activeUsers = data.data?.filter(user => user.is_active && !user.is_blocked).length || 0;
                document.getElementById('activeUsers').innerHTML = activeUsers;
            } else {
                console.error('Users API returned error:', data.message);
                document.getElementById('usersLoader').style.display = 'none';
                document.getElementById('activeUsers').innerHTML = '0';
            }
        })
        .catch(error => {
            console.error('Error loading users:', error);
            document.getElementById('usersLoader').style.display = 'none';
            document.getElementById('activeUsers').innerHTML = '0';
        });
}

// Fallback function to load individual stats
function loadIndividualStats() {
    // Load roles count
    fetch('/admin/api/rbac/roles')
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('rolesLoader').style.display = 'none';
                document.getElementById('totalRoles').innerHTML = data.pagination?.totalItems || data.data?.length || 0;
            } else {
                document.getElementById('rolesLoader').style.display = 'none';
                document.getElementById('totalRoles').innerHTML = '0';
            }
        })
        .catch(error => {
            console.error('Error loading roles:', error);
            document.getElementById('rolesLoader').style.display = 'none';
            document.getElementById('totalRoles').innerHTML = '0';
        });

    // Load permissions count
    fetch('/admin/api/rbac/permissions')
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('permissionsLoader').style.display = 'none';
                document.getElementById('totalPermissions').innerHTML = data.data?.length || 0;
            } else {
                document.getElementById('permissionsLoader').style.display = 'none';
                document.getElementById('totalPermissions').innerHTML = '0';
            }
        })
        .catch(error => {
            console.error('Error loading permissions:', error);
            document.getElementById('permissionsLoader').style.display = 'none';
            document.getElementById('totalPermissions').innerHTML = '0';
        });
}

// Load dashboard stats on page load
document.addEventListener('DOMContentLoaded', function() {
    loadDashboardStats();
});

</script>
